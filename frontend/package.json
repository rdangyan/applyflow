{
  "name": "applyflow-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run generate:api && tsc -b && vite build",
    "generate:api": "openapi --input ../backend/openapi/applyflow-v1.yaml --output src/generated --client fetch --useOptions",
    "check:api": "npm run generate:api && git diff --exit-code -- src/generated",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "7.2.0",
    "@mui/material": "7.2.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-router-dom": "7.7.1"
  },
  "devDependencies": {
    "@eslint/js": "9.31.0",
    "@testing-library/jest-dom": "6.6.4",
    "@testing-library/react": "16.3.0",
    "@types/node": "24.0.15",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "@vitejs/plugin-react": "4.7.0",
    "eslint": "9.31.0",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.20",
    "globals": "16.3.0",
    "jsdom": "26.1.0",
    "openapi-typescript-codegen": "0.29.0",
    "typescript": "5.8.3",
    "typescript-eslint": "8.38.0",
    "vite": "7.3.6",
    "vitest": "3.2.7"
  }
}
